#!/usr/bin/env bash
#
# kernel-store-producer — build the kernel store and deploy it to the workers.
#
# Builds the whole store (distro + upstream kernels) into a temp dir, tars
# it, and ships the tarball to every CI executor host in ktest-ci.json5. On each
# worker the tarball is unpacked into ~/.ktest/kernels-new and swapped into
# place against ~/.ktest/kernels with `mv --exchange`; the displaced old
# store is then removed.
#
# The tarball is kept across runs — overwritten by the next pack — so a
# failed deploy can be retried with --deploy-only without rebuilding.
#
# Modes (default is build + pack + deploy in one shot):
#   --pack-only      Build + pack, then stop.
#   --deploy-only    Skip build/pack; deploy the existing tarball.
#   --dry-run, -n    Print scp/ssh deploy commands instead of running them.

set -o nounset
set -o errexit
set -o errtrace
set -o pipefail

ktest_dir=$(dirname "$(readlink -f "$0")")
KTEST_DATA="${KTEST_DATA:-$HOME/.ktest}"
CONFIG_PATH="${KTEST_CI_CONFIG:-$KTEST_DATA/ktest-ci.json5}"

SSH="ssh -o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new"

# Build the store into a real-disk staging dir (it's many GB — keep it off
# /tmp, which may be tmpfs). Script-scoped, not main()-local, so the EXIT
# trap can still see them after main() returns.
new="$KTEST_DATA/kernels-new"
tarball="$new.tar.zst"

log() { echo "kernel-store-producer: $*"; }

usage() {
    cat <<EOF
Usage: kernel-store-producer [OPTIONS]

  --pack-only        Build and pack only; leave the tarball at
                     $tarball for a later deploy.
  --deploy-only      Skip build/pack; deploy the existing tarball at
                     $tarball.
  --dry-run, -n      Print scp/ssh deploy commands instead of running them.
  -h, --help         Show this help.

Default: build + pack + deploy.
EOF
}

do_pack=true
do_deploy=true
dry_run=false

while (($#)); do
    case $1 in
        --pack-only)   do_deploy=false ;;
        --deploy-only) do_pack=false ;;
        --dry-run|-n)  dry_run=true ;;
        -h|--help)     usage; exit 0 ;;
        *)             log "unknown argument: $1"; usage >&2; exit 1 ;;
    esac
    shift
done

# Clean up the build staging dir on exit. The tarball is intentionally
# kept across runs: it gets overwritten by the next pack anyway, and
# keeping it means --deploy-only can retry after a deploy failure
# without rebuilding the whole kernel store.
if $do_pack; then
    trap 'rm -rf "$new"' EXIT
fi

# JSON5 → JSON: strip // comments (only after whitespace/SOL so URLs
# survive), drop trailing commas, quote unquoted object keys. Same
# reader as upstream-kernel-build / ktest-deploy.
json5_to_json() {
    perl -0777 -pe '
	s{(^|\s)//[^\n]*}{$1}gm;
	s/,(\s*[}\]])/$1/g;
	s/([\{,\[]\s*|^\s*)([A-Za-z_][A-Za-z0-9_]*)(\s*):/$1"$2"$3:/gm;
    ' "$1"
}

# The deploy targets, one host per line. The kernel store goes to exactly
# the machines that run tests, so this is the same ktest-ci.json5 executor
# list ci-daemon / ktest-deploy read — one source of truth.
read_workers() {
    [[ -f $CONFIG_PATH ]] || { log "no config at $CONFIG_PATH"; exit 1; }
    json5_to_json "$CONFIG_PATH" | jq -r '.executors | keys[]'
}

# Print-or-run wrapper for --dry-run. Used for the outward-facing deploy
# commands (scp/ssh) only; local pack/build commands are not gated, since
# you can already skip them with --deploy-only.
run() {
    if $dry_run; then
        echo "kernel-store-producer: DRY-RUN: $*"
    else
        "$@"
    fi
}

# Deploy the packed store to a single worker. Returns non-zero on any failure
# (unreachable host, scp/ssh error) instead of aborting, so the deploy loop can
# tolerate individual worker failures — one dead box must not waste the whole
# build.
deploy_to() {
    local worker=$1
    run scp -q "$tarball" "$worker:.ktest/kernel-store.tar.zst" || return 1
    run $SSH "$worker" '
        set -e
        cd .ktest
        rm -rf kernels-new
        tar --zstd -xf kernel-store.tar.zst
        # -T: kernels is the literal target, not a dir to move into.
        # mkdir -p: --exchange needs both dirs (first deploy has none).
        mkdir -p kernels
        mv -T --exchange kernels-new kernels
        rm -rf kernels-new
    ' || return 1
}

main() {
    if $do_pack; then
        log "fetching distro kernels"
        "$ktest_dir/target/release/distro-kernel-fetch" --output "$new"

        log "building upstream kernels"
        "$ktest_dir/upstream-kernel-build" -o "$new"

        log "packing tarball"
        # Archive the kernels-new/ directory itself, so the tarball has a
        # single toplevel dir rather than exploding into the cwd.
        tar --zstd -cf "$tarball" -C "$KTEST_DATA" kernels-new
    fi

    if $do_deploy; then
        [[ -f $tarball ]] || { log "no tarball at $tarball (run --pack-only first?)"; exit 1; }

        # A single unreachable / decommissioned worker must not abort the run:
        # the build is expensive and the reachable workers still need the
        # store. Warn-and-continue per worker; fail only if none took it.
        local -a workers failed
        mapfile -t workers < <(read_workers)
        local ok=0

        for worker in "${workers[@]}"; do
            log "deploying to $worker"
            if deploy_to "$worker"; then
                ok=$((ok + 1))
            else
                log "WARNING: deploy to $worker failed — store NOT updated there, continuing"
                failed+=("$worker")
            fi
        done

        if (( ${#failed[@]} )); then
            log "deployed to $ok/${#workers[@]} workers; failed: ${failed[*]}"
        fi
        if (( ok == 0 )); then
            log "deploy failed: no workers received the store"
            exit 1
        fi
    fi

    log "done"
}

main
