#!/usr/bin/env bash
#
# upstream-kernel-build — track upstream linux source trees, build N variants
# per source, publish into the kernel store ($HOME/.ktest/kernels/upstream/).
#
# Drives build-test-kernel's `build` command under the hood. Config is
# json5 (see upstream-builds.json5.example); state lives under $HOME/.ktest/:
#
#   upstream-srcs/<release>.git/             bare clones (one per source, fetched)
#   upstream-builds/<release>-<variant>/     dedicated working clones
#                                            (one per release×variant; sidesteps
#                                             git's multi-process worktree races)
#   kernels/upstream/<release>-<variant>/<arch>/<version>/   store entries
#
# Run periodically; memoized by manifest.json presence (a successful build
# leaves a manifest, an interrupted one doesn't, so reruns retry only what's
# missing).

set -o nounset
set -o errexit
set -o errtrace

ktest_dir=$(dirname "$(readlink -f "$0")")
KTEST_DATA="${KTEST_DATA:-$HOME/.ktest}"
CONFIG_PATH="$KTEST_DATA/upstream-builds.json5"
ARCH="$(uname -m)"
DRY_RUN=false
VERBOSE=false
FORCE=false
BUILD_FILTER=""
PUSH=false

usage() {
    cat <<EOF
upstream-kernel-build — fetch + build configured upstream kernel sources.

Usage: upstream-kernel-build [options]

  -c <file>     config (default: $CONFIG_PATH)
  -a <arch>     architecture (default: $ARCH)
  -b <name>     build only this <release>-<variant> (e.g. stable-default)
  -f            force rebuild (ignore manifest, wipe matching store entries)
  -n            dry run (no fetch, no build)
  -p            build into a staging dir, then kernel-store-push to all workers
  -v            verbose
  -h            this help
EOF
}

while getopts "c:a:b:fnpvh" arg; do
    case $arg in
	c) CONFIG_PATH=$OPTARG ;;
	a) ARCH=$OPTARG ;;
	b) BUILD_FILTER=$OPTARG ;;
	f) FORCE=true ;;
	n) DRY_RUN=true ;;
	p) PUSH=true ;;
	v) VERBOSE=true ;;
	h) usage; exit 0 ;;
	*) usage; exit 1 ;;
    esac
done

SRCS_DIR="$KTEST_DATA/upstream-srcs"
BUILDS_DIR="$KTEST_DATA/upstream-builds"
# A plain run publishes into the live store, so an interactive build can
# be booted straight away. -p builds into a staging dir and never touches
# the live store — kernel-store-push then deploys it atomically.
KERNELS_DIR="$KTEST_DATA/$($PUSH && echo kernel-build || echo kernels)/upstream"
WORK_DIR="$KTEST_DATA/_work"

log()   { echo "upstream-kernel-build: $*"; }
vlog()  { $VERBOSE && echo "    $*" || true; }

# JSON5 → JSON: strip // comments + trailing commas, quote unquoted
# keys. We match // only when preceded by whitespace or at start-of-line,
# so URLs like git:// inside strings survive. Good enough for short,
# hand-edited config files; not a general parser.
json5_to_json() {
    # JSON5 → JSON via perl one-liner (sed -z's bracket classes don't
    # treat \n as whitespace, which makes trailing-comma stripping a
    # pain; perl just handles it). Adequate for short hand-edited
    # configs; not a general parser.
    perl -0777 -pe '
	# Strip // comments — only when preceded by whitespace or at
	# start-of-line, so URLs (git://, http://) survive.
	s{(^|\s)//[^\n]*}{$1}gm;
	# Drop trailing commas before } or ].
	s/,(\s*[}\]])/$1/g;
	# Quote unquoted object keys (multi-line and inline forms).
	s/([\{,\[]\s*|^\s*)([A-Za-z_][A-Za-z0-9_]*)(\s*):/$1"$2"$3:/gm;
    ' "$1"
}

read_config() {
    if [[ ! -f $CONFIG_PATH ]]; then
	log "no config at $CONFIG_PATH"
	exit 1
    fi
    json5_to_json "$CONFIG_PATH"
}

# Emit one tab-separated `source\turl` line per source.
list_sources() {
    read_config | jq -r '
	.sources | to_entries[]
	| [.key, .value] | @tsv
    '
}

# Emit one tab-separated `release\tvariant\tsource\tbranch\turl` line per
# build. Branch is "-" (not empty) when the release tracks the source's
# whole tag history — bash's `read -r` with IFS=$'\t' treats TAB as
# whitespace and collapses consecutive delimiters, which would otherwise
# shift `url` into `branch` on the no-branch case.
list_builds() {
    read_config | jq -r '
	.sources as $s
	| .builds | to_entries[]
	| .key as $rel
	| .value as $b
	| $b.variants[]
	| [$rel, ., $b.source, ($b.branch // "-"), ($s[$b.source] // "MISSING")] | @tsv
    '
}

# Resolve a release to its latest tag. With a branch, only tags reachable
# from that branch are considered (so stable-6.17 tied to linux-6.17.y
# picks the latest v6.17.* rather than the highest tag in the repo).
# rc releases pick vX.Y-rcN; everything else picks vX.Y.Z.
resolve_tag() {
    local release=$1 source=$2 branch=$3
    local bare="$SRCS_DIR/$source.git"
    local pattern
    case "$release" in
	*rc*)    pattern='^v[0-9]+\.[0-9]+-rc[0-9]+$' ;;
	*)       pattern='^v[0-9]+\.[0-9]+(\.[0-9]+)?$' ;;
    esac
    if [[ $branch != "-" ]]; then
	git -C "$bare" tag --merged "$branch" --sort=-v:refname \
	    | grep -E "$pattern" \
	    | head -1
    else
	git -C "$bare" tag --sort=-v:refname \
	    | grep -E "$pattern" \
	    | head -1
    fi
}

ensure_bare_clone() {
    local source=$1 url=$2
    local dir="$SRCS_DIR/$source.git"
    mkdir -p "$SRCS_DIR"
    if [[ ! -d $dir ]]; then
	log "cloning $url → $dir (first run, may take a while)"
	$DRY_RUN || git clone --quiet --bare "$url" "$dir"
    else
	vlog "fetching $dir"
	$DRY_RUN || git -C "$dir" fetch --quiet --tags --force origin
    fi
}

# A dedicated working clone per (release, variant). `--reference <bare>`
# shares object storage with the bare clone so we don't duplicate the
# kernel's history on disk per variant; each clone has its own .git
# state, so concurrent builds across variants don't race on refs/HEAD.
ensure_build_repo() {
    local source=$1 release=$2 variant=$3
    local bare="$SRCS_DIR/$source.git"
    local dir="$BUILDS_DIR/$release-$variant"
    mkdir -p "$BUILDS_DIR"
    if [[ ! -d $dir/.git ]]; then
	log "init build repo $dir"
	$DRY_RUN || git clone --quiet --reference "$bare" --shared "$bare" "$dir"
    fi
}

already_have() {
    local release=$1 variant=$2 version=$3
    [[ -f $KERNELS_DIR/$release-$variant/$ARCH/$version/manifest.json ]]
}

build_one() {
    local release=$1 variant=$2 source=$3 branch=$4 url=$5
    local bare="$SRCS_DIR/$source.git"
    local build_repo="$BUILDS_DIR/$release-$variant"

    # On a dry-run the bare clone hasn't been fetched, so we can't
    # resolve_tag. Report the intended action and bail without touching
    # the filesystem.
    if $DRY_RUN; then
	log "would build upstream/$release-$variant (tag resolved at run time)"
	return 0
    fi

    local tag
    tag=$(resolve_tag "$release" "$source" "$branch") || true
    if [[ -z $tag ]]; then
	log "no matching tag for release=$release (skipping $variant)"
	return 0
    fi
    local version=${tag#v}

    local destdir="$KERNELS_DIR/$release-$variant/$ARCH/$version"

    if ! $FORCE && already_have "$release" "$variant" "$version"; then
	log "have upstream/$release-$variant/$ARCH/$version"
	return 0
    fi

    ensure_build_repo "$source" "$release" "$variant"
    git -C "$build_repo" fetch --quiet "$bare" "+refs/tags/$tag:refs/tags/$tag"
    git -C "$build_repo" reset --quiet --hard "$tag"
    git -C "$build_repo" clean -qfdx

    local workdir="$WORK_DIR/upstream-$release-$variant-$ARCH"
    mkdir -p "$workdir" "$(dirname "$destdir")"

    log "building upstream/$release-$variant @ $tag → $destdir"

    # Build inside a Debian rootfs via systemd-nspawn. The kernel's
    # scripts/* (fixdep, modpost, dtc, ...) become real ELF binaries
    # linked against whatever libc + ld.so the build host has. On a
    # NixOS build host they'd be /nix/store-anchored, which makes
    # subsequent dkms builds on Debian workers fail with a confusing
    # "file not found" (the missing file is the ELF interpreter, not
    # the binary itself). Wrapping in the same Debian rootfs the
    # workers run keeps the toolchain uniform end-to-end.
    #
    # The rootfs is mounted read-only with an overlay so concurrent
    # builds (and the workers using the same image) don't step on
    # each other; the overlay is discarded when nspawn exits.
    case "$ARCH" in
	x86_64|amd64)   debian_arch=amd64 ;;
	aarch64|arm64)  debian_arch=arm64 ;;
	*)              debian_arch=$ARCH ;;
    esac

    # If the host is already Debian/Ubuntu and matches the target arch,
    # the nspawn wrapper isn't needed — host scripts/* will be linked
    # against the same libc + ld.so the workers run.
    local host_distro=""
    [[ -f /etc/os-release ]] && host_distro=$(. /etc/os-release && echo "$ID")
    local host_debian_arch
    host_debian_arch=$(dpkg --print-architecture 2>/dev/null || true)
    # On force rebuild, wipe any existing entry. nspawn writes files as
    # root, so the wipe needs the same privilege context — defer the rm
    # to inside the nspawn shell for the nspawn path; for host-fallback
    # the existing files are user-owned (nspawn was never available) so
    # plain rm works.
    if [[ ($host_distro = debian || $host_distro = ubuntu) &&
	  $host_debian_arch = $debian_arch ]]; then
	log "host is $host_distro/$host_debian_arch matching target — skipping nspawn"
	$FORCE && rm -rf "$destdir"
	"$ktest_dir/build-test-kernel" build \
	    -V "$variant" -a "$ARCH" -k "$build_repo" -o "$workdir" -D "$destdir"
	return
    fi

    local rootfs=""
    for candidate in "$HOME/.ktest/root.$debian_arch" "/var/lib/ktest/root.$debian_arch"; do
	[[ -f $candidate ]] && { rootfs=$candidate; break; }
    done
    if [[ -z $rootfs ]]; then
	log "no Debian root image (root.$debian_arch) found; falling back to host build"
	$FORCE && rm -rf "$destdir"
	"$ktest_dir/build-test-kernel" build \
	    -V "$variant" -a "$ARCH" -k "$build_repo" -o "$workdir" -D "$destdir"
	return
    fi

    local pre_cmd=""
    $FORCE && pre_cmd="rm -rf '$destdir';"

    # nspawn doesn't sanitize PATH — on NixOS hosts it leaks the host's
    # nix-store PATH into the container, where none of the Debian binaries
    # are reachable. Override with a Debian-sensible PATH.
    local machine="ktest-build-$$-$release-$variant"
    sudo systemd-nspawn \
	--image="$rootfs" \
	--read-only \
	--volatile=overlay \
	--quiet \
	--machine="$machine" \
	--bind-ro="$ktest_dir" \
	--bind-ro="$bare" \
	--bind="$build_repo" \
	--bind="$workdir" \
	--bind="$(dirname "$destdir")" \
	--setenv=HOME=/root \
	--setenv=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
	/bin/bash -c "
	    set -e
	    $pre_cmd
	    git config --global --add safe.directory '$build_repo'
	    '$ktest_dir/build-test-kernel' build \
		-V '$variant' -a '$ARCH' \
		-k '$build_repo' -o '$workdir' -D '$destdir'
	"

    # nspawn ran the build as root, so the freshly-written store entry is
    # root-owned. Hand it back to the invoking user: kernel-store-push runs
    # unprivileged, and a later force-rebuild's `rm -rf` would fail on it.
    sudo chown -R "$(id -u):$(id -g)" "$destdir"
}

main() {
    mkdir -p "$KERNELS_DIR" "$WORK_DIR"

    # Phase 1: fetch every distinct source tree. Sources are now
    # shared across releases (eg. stable, stable-6.17, stable-6.18 all
    # alias one linux-stable bare clone).
    while IFS=$'\t' read -r source url; do
	ensure_bare_clone "$source" "$url"
    done < <(list_sources)

    # Phase 2: build each (release, variant) that isn't already in the store.
    local failed=0
    while IFS=$'\t' read -r release variant source branch url; do
	if [[ -n $BUILD_FILTER && "$release-$variant" != "$BUILD_FILTER" ]]; then
	    continue
	fi
	if [[ $url = MISSING ]]; then
	    log "release '$release' references unknown source '$source'"
	    failed=$((failed + 1))
	    continue
	fi
	if ! build_one "$release" "$variant" "$source" "$branch" "$url"; then
	    log "ERROR: $release/$variant"
	    failed=$((failed + 1))
	fi
    done < <(list_builds)

    if [[ $failed -gt 0 ]]; then
	log "$failed build(s) failed"
	exit 1
    fi

    # -p: hand the freshly-built staging store to kernel-store-push, which
    # deploys it to every worker — atomic per-entry rename, so a running
    # test never sees a half-synced store.
    if $PUSH; then
	local push_args=(-s "$KTEST_DATA/kernel-build")
	$FORCE && push_args+=(-f)
	$DRY_RUN && push_args+=(-n)
	$VERBOSE && push_args+=(-v)
	log "deploying kernel store to workers"
	"$ktest_dir/kernel-store-push" "${push_args[@]}"
    fi
}

main "$@"
