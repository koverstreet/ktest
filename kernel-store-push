#!/usr/bin/env bash
#
# kernel-store-push — atomically push the local kernel store to farm workers.
#
# For each configured worker, lists the entries already present on it
# (manifest.json marker present = "live entry"), then rsyncs each missing
# entry into a hidden staging dir on the worker and renames it onto its
# final location. The rename(2) is atomic on a single filesystem; readers
# see either old-version or new-version, never half-synced.
#
# We don't delete on the worker side. Old versions accumulate until a
# separate scheduled prune removes them; that's intentional so a
# running test referencing an older kernel doesn't get files yanked
# mid-run.

set -o nounset
set -o errexit
set -o errtrace

KTEST_DATA="${KTEST_DATA:-$HOME/.ktest}"
CONFIG_PATH="$KTEST_DATA/farm-workers.json5"
SRC_KERNELS="$KTEST_DATA/kernels"
DRY_RUN=false
VERBOSE=false
FORCE=false

# ssh for bare remote commands. -n is load-bearing: these run inside a
# `while read` loop over the worker list, and without it the first ssh
# reads (and swallows) the rest of that list off stdin, so the loop only
# ever processes one worker. accept-new: producer host -> worker is
# usually first contact.
SSH="ssh -n -o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new"
RSYNC_SSH="ssh -o BatchMode=yes -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new"

usage() {
    cat <<EOF
kernel-store-push — atomically rsync the kernel store to farm workers.

Usage: kernel-store-push [options]

  -c <file>     config (default: $CONFIG_PATH)
  -s <dir>      kernel store to push from (default: $SRC_KERNELS)
  -f            force: re-push every entry, replacing any already present
  -n            dry run (list what would be pushed; no rsync)
  -v            verbose
  -h            this help
EOF
}

while getopts "c:s:fnvh" arg; do
    case $arg in
	c) CONFIG_PATH=$OPTARG ;;
	s) SRC_KERNELS=$OPTARG ;;
	f) FORCE=true ;;
	n) DRY_RUN=true ;;
	v) VERBOSE=true ;;
	h) usage; exit 0 ;;
	*) usage; exit 1 ;;
    esac
done

log()  { echo "kernel-store-push: $*"; }
vlog() { $VERBOSE && echo "    $*" || true; }

# JSON5 → JSON via perl one-liner (sed -z's bracket classes don't treat
# \n as whitespace; perl just handles it). Same shape as
# upstream-kernel-build's reader.
json5_to_json() {
    perl -0777 -pe '
	# Strip // comments (only when preceded by whitespace / start-of-line,
	# so URLs inside strings — git://, http:// — survive).
	s{(^|\s)//[^\n]*}{$1}gm;
	# Drop trailing commas before } or ].
	s/,(\s*[}\]])/$1/g;
	# Quote unquoted object keys. Match keys that are at line-start
	# (multi-line config) AND keys that follow `{`, `,`, or `[` on the
	# same line (inline config).
	s/([\{,\[]\s*|^\s*)([A-Za-z_][A-Za-z0-9_]*)(\s*):/$1"$2"$3:/gm;
    ' "$1"
}

read_workers() {
    if [[ ! -f $CONFIG_PATH ]]; then
	log "no config at $CONFIG_PATH"
	exit 1
    fi
    # Emit one tab-separated `target\tremote_data` line per worker.
    json5_to_json "$CONFIG_PATH" | jq -r '
	.workers[]
	| [.target, (.remote_data // ".ktest")] | @tsv
    '
}

# Enumerate local kernel-store entries as `<distro>/<release>/<arch>/<version>` paths.
local_entries() {
    [[ -d $SRC_KERNELS ]] || return 0
    find "$SRC_KERNELS" -name manifest.json -type f 2>/dev/null \
	| sed "s|^$SRC_KERNELS/||; s|/manifest.json$||" \
	| sort
}

# What's already on the worker? One ssh roundtrip per worker.
remote_entries() {
    local target=$1 remote_data=$2
    $SSH "$target" \
	"find $remote_data/kernels -name manifest.json -type f 2>/dev/null \
	 | sed 's|.*/kernels/||; s|/manifest.json\$||'" 2>/dev/null \
	| sort || true
}

push_entry() {
    local target=$1 remote_data=$2 entry=$3
    local src="$SRC_KERNELS/$entry"
    local rel_parent rel_leaf
    rel_parent=$(dirname "$entry")
    rel_leaf=$(basename "$entry")

    local remote_parent="$remote_data/kernels/$rel_parent"
    local remote_final="$remote_parent/$rel_leaf"
    # Staging name: leading '.' hides it from glob-based enumerations and
    # the manifest.json check above; '$$' is unique per push run.
    local remote_staging="$remote_parent/.$rel_leaf.staging.$$"

    if $DRY_RUN; then
	log "[DRY] $target: $entry"
	return 0
    fi

    vlog "$target: $entry"
    # Make sure remote parent exists; clean any prior staging from a
    # previous interrupted push.
    $SSH "$target" \
	"mkdir -p '$remote_parent' && rm -rf '$remote_staging'"

    # Rsync into the staging dir. Trailing '/' on src means "copy contents
    # of $src into $remote_staging/" (so $remote_staging is the new entry
    # root, mirroring $src).
    rsync -a --quiet -e "$RSYNC_SSH" \
	"$src/" "$target:$remote_staging/"

    # -f: replace the entry in place. Swap the old one aside, move the new
    # one in, drop the old — two back-to-back renames, so the window where
    # $remote_final is briefly absent is negligible. A test already running
    # off this kernel keeps its files through its open fds.
    if $FORCE; then
	local remote_old="$remote_parent/.$rel_leaf.old.$$"
	if ! $SSH "$target" "set -e
		rm -rf '$remote_old'
		if [ -e '$remote_final' ]; then
		    mv -T '$remote_final' '$remote_old'
		fi
		mv -T --no-target-directory '$remote_staging' '$remote_final'
		rm -rf '$remote_old'"; then
		log "WARN: $target: $entry: replace failed"
		$SSH "$target" "rm -rf '$remote_staging' '$remote_old'" || true
		return 1
	fi
	return 0
    fi

    # Atomic rename. mv -T on a single filesystem is rename(2); a reader
    # sees either no entry at $remote_final (not yet) or a complete entry
    # (manifest.json present), never partial.
    #
    # If $remote_final somehow already exists (race: another concurrent
    # push, or the entry was just published from elsewhere), our
    # `--no-target-directory` would refuse — bail and clean up staging.
    if ! $SSH "$target" \
	    "mv -T --no-target-directory '$remote_staging' '$remote_final'"; then
	log "WARN: $target: $entry: rename failed (raced?)"
	$SSH "$target" "rm -rf '$remote_staging'" || true
	return 1
    fi
}

push_to_worker() {
    local target=$1 remote_data=$2
    log "$target"

    local on_remote
    on_remote=$(remote_entries "$target" "$remote_data") || {
	log "  $target: unreachable"
	return 1
    }

    # -f re-pushes every entry — a rebuild can change an entry's contents
    # without changing its version. Otherwise push only what the worker is
    # missing (comm -23 = lines in the first list absent from the second).
    local to_push
    if $FORCE; then
	to_push=$(local_entries)
    else
	to_push=$(comm -23 <(local_entries) <(echo "$on_remote"))
    fi

    if [[ -z $to_push ]]; then
	log "  $target: up to date"
	return 0
    fi

    local count=0
    while IFS= read -r entry; do
	[[ -n $entry ]] || continue
	if push_entry "$target" "$remote_data" "$entry"; then
	    count=$((count + 1))
	fi
    done <<<"$to_push"
    log "  $target: pushed $count entries"
}

main() {
    if [[ ! -d $SRC_KERNELS ]]; then
	log "no local kernels at $SRC_KERNELS"
	exit 1
    fi

    local failed=0
    while IFS=$'\t' read -r target remote_data; do
	[[ -n $target ]] || continue
	if ! push_to_worker "$target" "$remote_data"; then
	    failed=$((failed + 1))
	fi
    done < <(read_workers)

    if [[ $failed -gt 0 ]]; then
	log "$failed worker(s) had failures"
	exit 1
    fi
}

main "$@"
