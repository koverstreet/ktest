#!/usr/bin/env bash
# CI worker driver — runs test-git-branch inside a nix shell with all
# build dependencies (including Rust stdlib sources for kernel Rust
# builds).
#
# Deploy this as the CI worker entry point instead of running
# test-git-branch directly.
#
# Usage: ci/ci-worker [test-git-branch args...]

set -euo pipefail

KTEST_DIR=$(dirname "$(readlink -e "$0")")/..

BIN="$KTEST_DIR/target/release/test-git-branch"
[[ -x $BIN ]] || BIN="$KTEST_DIR/target/debug/test-git-branch"

exec nix-shell "$KTEST_DIR/ci/shell.nix" \
    --run "exec '$BIN' $(printf '%q ' "$@")"
