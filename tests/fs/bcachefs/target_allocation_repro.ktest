#!/usr/bin/env bash

. $(dirname $(readlink -e ${BASH_SOURCE[0]}))/bcachefs-test-libs.sh

require-kernel-config BCACHEFS_FS=y

config-scratch-devs 256M
config-scratch-devs 512M
config-scratch-devs 2G

devs()
{
    join_by : "${ktest_scratch_dev[@]}"
}

dump_allocator_state()
{
    local uuid=$1

    bcachefs fs usage -h /mnt || true

    for d in /sys/fs/bcachefs/$uuid/dev-*; do
        echo "dev=${d##*/} label=$(cat "$d/label") state=$(cat "$d/state") data_allowed=$(cat "$d/data_allowed")"
        sed -n '1,80p' "$d/alloc_debug"
    done

    cat /sys/fs/bcachefs/$uuid/recovery_status || true
    cat /sys/fs/bcachefs/$uuid/internal/moving_ctxts || true
}

dev_sysfs_by_label()
{
    local uuid=$1
    local label=$2

    for d in /sys/fs/bcachefs/$uuid/dev-*; do
        if [[ $(cat "$d/label") = "$label" ]]; then
            echo "$d"
            return 0
        fi
    done

    return 1
}

alloc_buckets_by_label()
{
    local uuid=$1
    local label=$2
    local type=$3

    awk -v type="$type" '$1 == type { print $2 }' \
        "$(dev_sysfs_by_label "$uuid" "$label")/alloc_debug"
}

wait_for_reconcile_idle()
{
    local uuid=$1
    local deadline=$((SECONDS + 120))
    local prev_moving=""
    local prev_pending=""
    local stable=0

    while (( SECONDS < deadline )); do
        local moving=$(cat "/sys/fs/bcachefs/$uuid/internal/moving_ctxts" 2>/dev/null || true)
        local pending=$(cat "/sys/fs/bcachefs/$uuid/reconcile_scan_pending" 2>/dev/null || true)

        if [[ $moving = "$prev_moving" ]] &&
           [[ $pending = "$prev_pending" ]] &&
           [[ $pending = 0 ]]; then
            (( ++stable >= 3 )) && return 0
        else
            stable=0
        fi

        prev_moving=$moving
        prev_pending=$pending
        sleep 1
    done

    echo "startup reconcile did not go idle"
    dump_allocator_state "$uuid"
    return 1
}

wait_for_background_target_migration()
{
    local uuid=$1
    local ssd_label=$2
    local hdd_label=$3
    local ssd_before=$4
    local hdd_before=$5
    local deadline=$((SECONDS + 120))

    while (( SECONDS < deadline )); do
        local ssd_after=$(alloc_buckets_by_label "$uuid" "$ssd_label" user)
        local hdd_after=$(alloc_buckets_by_label "$uuid" "$hdd_label" user)

        if (( ssd_after * 2 <= ssd_before && hdd_after > hdd_before )); then
            return 0
        fi

        sleep 1
    done

    return 1
}

wait_for_ssd_cached_buckets_increase()
{
    local uuid=$1
    local ssd_label=$2
    local cached_before=$3
    local deadline=$((SECONDS + 120))

    while (( SECONDS < deadline )); do
        local cached_after=$(alloc_buckets_by_label "$uuid" "$ssd_label" cached)

        if (( cached_after > cached_before )); then
            return 0
        fi

        sleep 1
    done

    return 1
}

assert_ssd_write_precondition()
{
    local uuid=$1
    local ssd_label=$2
    local ssd_before=$3

    if (( ssd_before == 0 )); then
        echo "write did not allocate user buckets on SSD"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi
}

assert_initial_background_target_shape()
{
    local uuid=$1
    local ssd_label=$2
    local hdd_label=$3
    local ssd_before=$4
    local hdd_before=$5
    local cached_before=$(alloc_buckets_by_label "$uuid" "$ssd_label" cached)

    if (( ssd_before == 0 && cached_before > 0 && hdd_before > 0 )); then
        return 0
    fi

    assert_ssd_write_precondition "$uuid" "$ssd_label" "$ssd_before" || return 1
    assert_background_target_migration "$uuid" "$ssd_label" "$hdd_label" "$ssd_before" "$hdd_before"
}

assert_background_target_migration()
{
    local uuid=$1
    local ssd_label=$2
    local hdd_label=$3
    local ssd_before=$4
    local hdd_before=$5

    if ! wait_for_background_target_migration "$uuid" "$ssd_label" "$hdd_label" "$ssd_before" "$hdd_before"; then
        local ssd_after=$(alloc_buckets_by_label "$uuid" "$ssd_label" user)
        local hdd_after=$(alloc_buckets_by_label "$uuid" "$hdd_label" user)

        echo "background_target=hdd did not move at least half of SSD user buckets"
        echo "ssd_before=$ssd_before ssd_after=$ssd_after hdd_before=$hdd_before hdd_after=$hdd_after"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi
}

test_background_target_initial_idle_reconcile_progress()
{
    set_watchdog 180

    run_quiet "" bcachefs format -f                  \
        --block_size=4k                              \
        --bucket_size=256k                           \
        --label=ssd.cache ${ktest_scratch_dev[0]}    \
        --label=hdd.backing ${ktest_scratch_dev[2]}  \
        --foreground_target=ssd                      \
        --promote_target=ssd                         \
        --background_target=hdd

    mount -t bcachefs "${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}" /mnt
    uuid=$(basename /sys/fs/bcachefs/*)

    dd if=/dev/zero of=/mnt/writeback-data bs=4M count=32 oflag=direct status=none
    sync

    ssd_before=$(alloc_buckets_by_label "$uuid" ssd.cache user)
    hdd_before=$(alloc_buckets_by_label "$uuid" hdd.backing user)

    # No bcachefs reconcile wait here: this must make progress by the mounted
    # filesystem's own background reconcile thread, not by a userspace wakeup.
    assert_initial_background_target_shape "$uuid" ssd.cache hdd.backing "$ssd_before" "$hdd_before" || return 1

    umount /mnt
    bcachefs fsck -ny ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_background_target_changed_idle_reconcile_progress()
{
    set_watchdog 180

    run_quiet "" bcachefs format -f                  \
        --block_size=4k                              \
        --bucket_size=256k                           \
        --label=ssd.cache ${ktest_scratch_dev[0]}    \
        --label=hdd.backing ${ktest_scratch_dev[2]}  \
        --foreground_target=ssd                      \
        --promote_target=ssd                         \
        --background_target=ssd

    mount -t bcachefs "${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}" /mnt
    uuid=$(basename /sys/fs/bcachefs/*)

    dd if=/dev/zero of=/mnt/writeback-data bs=4M count=32 oflag=direct status=none
    sync

    ssd_before=$(alloc_buckets_by_label "$uuid" ssd.cache user)
    hdd_before=$(alloc_buckets_by_label "$uuid" hdd.backing user)
    assert_ssd_write_precondition "$uuid" ssd.cache "$ssd_before" || return 1

    umount /mnt

    # Persistently change the filesystem-wide background target while the
    # filesystem is stopped.  Existing extents have no per-extent target work
    # yet; startup must queue a reconcile scan and the idle reconciler must run
    # it without needing more foreground writes to advance the IO clock.
    bcachefs set-fs-option --background_target=hdd \
        ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}

    mount -t bcachefs "${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}" /mnt
    uuid=$(basename /sys/fs/bcachefs/*)

    if [[ $(cat /sys/fs/bcachefs/$uuid/options/background_target) != hdd ]]; then
        echo "background_target was not set to hdd"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi

    # No bcachefs reconcile wait here: startup must queue and run the scan
    # without a userspace trigger_reconcile_wakeup kick.
    assert_background_target_migration "$uuid" ssd.cache hdd.backing "$ssd_before" "$hdd_before" || return 1

    umount /mnt
    bcachefs fsck -ny ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_background_target_steady_state_idle_writeback_progress()
{
    set_watchdog 300

    run_quiet "" bcachefs format -f                  \
        --block_size=4k                              \
        --bucket_size=256k                           \
        --label=ssd.cache ${ktest_scratch_dev[0]}    \
        --label=hdd.backing ${ktest_scratch_dev[2]}  \
        --foreground_target=ssd                      \
        --promote_target=ssd                         \
        --background_target=hdd

    mount -t bcachefs "${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}" /mnt
    uuid=$(basename /sys/fs/bcachefs/*)

    wait_for_reconcile_idle "$uuid" || {
        umount /mnt || true
        return 1
    }

    dd if=/dev/zero of=/mnt/writeback-after-idle bs=4M count=32 oflag=direct status=none
    sync

    ssd_before=$(alloc_buckets_by_label "$uuid" ssd.cache user)
    hdd_before=$(alloc_buckets_by_label "$uuid" hdd.backing user)

    # Startup reconcile is already idle here; steady-state writeback must still
    # produce HDD-backed data without a remount or manual wakeup. Depending on
    # write timing, bcachefs may either first allocate ordinary SSD user buckets
    # and drain them, or immediately write durable HDD data plus an SSD cached
    # copy. Both satisfy the cache-tier promise.
    assert_initial_background_target_shape "$uuid" ssd.cache hdd.backing "$ssd_before" "$hdd_before" || return 1

    umount /mnt
    bcachefs fsck -ny ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_promote_target_reads_cache_hdd_data()
{
    set_watchdog 240

    run_quiet "" bcachefs format -f                  \
        --block_size=4k                              \
        --bucket_size=256k                           \
        --label=ssd.cache ${ktest_scratch_dev[0]}    \
        --label=hdd.backing ${ktest_scratch_dev[2]}  \
        --foreground_target=hdd                      \
        --promote_target=ssd                         \
        --background_target=hdd

    mount -t bcachefs "${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}" /mnt
    uuid=$(basename /sys/fs/bcachefs/*)

    wait_for_reconcile_idle "$uuid" || {
        umount /mnt || true
        return 1
    }

    dd if=/dev/zero of=/mnt/promote-on-read bs=4M count=32 oflag=direct status=none
    sync

    ssd_cached_before=$(alloc_buckets_by_label "$uuid" ssd.cache cached)
    hdd_user_before=$(alloc_buckets_by_label "$uuid" hdd.backing user)

    if (( hdd_user_before == 0 )); then
        echo "write did not allocate user buckets on HDD"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi

    echo 3 > /proc/sys/vm/drop_caches
    dd if=/mnt/promote-on-read of=/dev/null bs=4M status=none
    sync

    if ! wait_for_ssd_cached_buckets_increase "$uuid" ssd.cache "$ssd_cached_before"; then
        ssd_cached_after=$(alloc_buckets_by_label "$uuid" ssd.cache cached)
        hdd_user_after=$(alloc_buckets_by_label "$uuid" hdd.backing user)

        echo "read did not promote cached buckets onto SSD"
        echo "ssd_cached_before=$ssd_cached_before ssd_cached_after=$ssd_cached_after hdd_user_before=$hdd_user_before hdd_user_after=$hdd_user_after"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi

    hdd_user_after=$(alloc_buckets_by_label "$uuid" hdd.backing user)
    if (( hdd_user_after < hdd_user_before )); then
        echo "read promotion unexpectedly drained HDD user buckets"
        echo "hdd_user_before=$hdd_user_before hdd_user_after=$hdd_user_after"
        dump_allocator_state "$uuid"
        umount /mnt || true
        return 1
    fi

    umount /mnt
    bcachefs fsck -ny ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_foreground_target_exhausted_no_hang()
{
    set_watchdog 180

    run_quiet "" bcachefs format -f                  \
        --block_size=4k                              \
        --bucket_size=256k                           \
        --label=ssd.full ${ktest_scratch_dev[0]}     \
        --label=ssd.spare ${ktest_scratch_dev[1]}    \
        --label=hdd.free ${ktest_scratch_dev[2]}     \
        --foreground_target=ssd                      \
        --promote_target=ssd                         \
        --background_target=hdd

    mount -t bcachefs "$(devs)" /mnt

    uuid=$(basename /sys/fs/bcachefs/*)
    for d in /sys/fs/bcachefs/$uuid/dev-*; do
        if [[ $(cat "$d/label") = ssd.spare ]]; then
            echo ro > "$d/state"
        fi
    done

    # The preferred target is intentionally too small for this write, while
    # another rw device still has user data space. Targets are preferences, not
    # hard constraints: the write must fall back instead of waiting forever in
    # the allocator.
    dd if=/dev/zero of=/mnt/fill-ssd bs=4M count=160 oflag=direct status=none &
    writer=$!

    sleep 45

    if kill -0 "$writer" 2>/dev/null; then
        echo "foreground write still running after 45s; allocator appears stuck"
        cat "/proc/$writer/stack" || true
        dump_allocator_state "$uuid"

        # The writer is usually stuck in D state, so ordinary cleanup cannot
        # make progress. Emit the failure marker before powering off the guest
        # so the host-side runner has a bounded repro instead of a wedged VM.
        echo "TEST FAILED"
        sync
        echo o > /proc/sysrq-trigger
        sleep 5
        return 1
    fi

    wait "$writer"

    umount /mnt
    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
}

main "$@"
