#!/usr/bin/env bash

. $(dirname $(readlink -e "${BASH_SOURCE[0]}"))/bcachefs-test-libs.sh

#require-git http://evilpiepirate.org/git/linuxquota.git
#require-make linuxquota

. $(dirname $(readlink -e "${BASH_SOURCE[0]}"))/../fstests.sh

require-kernel-config BCACHEFS_QUOTA
require-kernel-config QUOTA

[[ ! -v MKFS_OPTIONS ]] && export MKFS_OPTIONS="--encrypted --no_passphrase --errors=ro"
export FSTYP=bcachefs

run_tests()
{
    # fstests includes crash-consistency tests (dm-flakey drop_writes,
    # log-writes) that legitimately produce checksum errors. Counters
    # reset on each test's mkfs, so what the end checks see is whatever
    # test formatted the scratch devs last - nondeterministic. Skip the
    # device error counter check for fstests runs.
    ktest_expect_device_errors=1

    if [[ ! -f /xfstests-init-done ]]; then
	bcachefs_antagonist
    fi

    # Expunges:
    # generic/064: we don't yet merge reflink pointers
    # generic/102: precise "write until fs is full" -ENOSPC semantics are not terribly useful
    # generic/275: precise "write until fs is full" -ENOSPC semantics are not terribly useful
    # generic/414: extents are smaller
    # generic/441: we don't yet support the fsync semantics of "only return an error once"
    # generic/558: extremely slow on bcachefs, mainly due to inodes being
    # smaller than other filesystems (thus we can fit a lot more)
    # generic/559: duperemove dedupe test on 2GB identical data; ~4GB of
    # comparison I/O (with decryption) exceeds 1200s timeout on CI VMs
    #
    # generic/219, generic/328, generic/762: quota failures that we don't care about yet
    # generic/757: dm logwrites test that needs to be tweaked for bcachefs, it doesn't purge the journal of entries from the future
    # generic/371: excessively strict -ENOSPC semantics
    # generic/065,generic/104,generic/336,generic/343,generic/376,generic/510: who drunkenly imagined up this "requirement" for fsync()? fsync the thing you want synced
    # generic/484: we don't guarantee that syncfs/fsync only returns the error once
    #
    # generic/622: test assumes drop_caches fully evicts, but shrinkers have a bug where they don't when nr_seeks == 0

    # Variant configs (e.g. fstests-largebs) add their own expunges via
    # $FSTESTS_EXPUNGE, exported before sourcing this file:
    run_fstests -e generic/064,generic/065,generic/102,generic/104,generic/275,generic/336,generic/343,generic/371,generic/376,generic/414,generic/441,generic/510,generic/558,generic/559,generic/219,generic/328,generic/484,generic/622,generic/762,generic/757${FSTESTS_EXPUNGE:+,$FSTESTS_EXPUNGE} "$@"

    bcachefs_test_end_checks ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}
}

main "$@"
