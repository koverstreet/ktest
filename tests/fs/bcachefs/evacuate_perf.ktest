#!/usr/bin/env bash

# shellcheck disable=SC1091,SC2034,SC2154
NO_BCACHEFS_DEBUG=1
NO_BCACHEFS_DEBUG_KEEP_LATENCY_ACCT=1

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/bcachefs-test-libs.sh"

require-kernel-config BCACHEFS_FS=y

config-mem 4G
config-scratch-slowdevs 2G
config-scratch-slowdevs 2G
config-scratch-slowdevs 2G

devs()
{
    join_by : "${ktest_scratch_dev[@]}"
}

trace_events()
{
    local t=/sys/kernel/tracing/events
    local events=(
	bcachefs:data_update_write
	bcachefs:data_update_fail
	bcachefs:bucket_alloc_fail
	bcachefs:open_bucket_alloc_fail
	bcachefs:journal_flush
	bcachefs:journal_write
	bcachefs:journal_reclaim_start
	bcachefs:journal_reclaim_finish
	bcachefs:journal_res_get_blocked
	block:block_bio_queue
	block:block_bio_complete
    )

    for event in "${events[@]}"; do
	local path="${event%%:*}/${event#*:}"
	if [[ -e $t/$path/enable ]]; then
	    echo "$event"
	fi
    done
}

dump_evacuate_perf_debug()
{
    bcachefs fs usage -h --all /mnt || true
    cat /sys/fs/bcachefs/*/reconcile_status || true
    cat /sys/fs/bcachefs/*/internal/copy_gc_wait || true
    cat /sys/fs/bcachefs/*/internal/moving_ctxts || true
    cat /sys/fs/bcachefs/*/journal_reclaim || true
    cat /sys/fs/bcachefs/*/time_stats/journal_flush_write || true
    cat /sys/fs/bcachefs/*/time_stats/journal_flush_seq || true
    cat /sys/fs/bcachefs/*/time_stats/journal_noflush_write || true
    cat /sys/fs/bcachefs/*/time_stats/blocked_journal_low_on_space || true
    cat /sys/fs/bcachefs/*/time_stats/blocked_journal_low_on_pin || true
    cat /sys/fs/bcachefs/*/time_stats/blocked_journal_max_in_flight || true
    cat /sys/fs/bcachefs/*/time_stats/blocked_journal_max_open || true
    cat /sys/kernel/debug/bcachefs/*/write_points || true
    tail -n 1200 /sys/kernel/tracing/trace || true
}

format_evacuate_perf_fs()
{
    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--bucket_size=256k				\
	--replicas=1					\
	--foreground_target=src				\
	--background_target=src				\
	--metadata_target=dst				\
	--rotational=1 --label=src "${ktest_scratch_dev[0]}" \
	--rotational=1 --label=dst "${ktest_scratch_dev[1]}" \
	--rotational=1 --label=dst "${ktest_scratch_dev[2]}"
}

seed_source_data()
{
    dd if=/dev/zero of=/mnt/src-only-data bs=4M count=128 oflag=direct status=none
    sync
}

read_bytes_per_sec()
{
    local file=$1
    local size=$2
    local start end elapsed_ns

    sync
    echo 3 > /proc/sys/vm/drop_caches

    start=$(date +%s%N)
    dd if="$file" of=/dev/null bs=4M iflag=direct status=none
    end=$(date +%s%N)

    elapsed_ns=$((end - start))
    (( elapsed_ns > 0 ))
    echo $((size * 1000000000 / elapsed_ns))
}

start_dst_pressure()
{
    local log=$1

    mkdir -p /mnt/dst-pressure
    bcachefs set-file-option --foreground_target=dst /mnt/dst-pressure
    dd if=/dev/zero of=/mnt/dst-pressure/hotfile bs=4M count=128 oflag=direct status=none
    sync
    echo 3 > /proc/sys/vm/drop_caches

    fio --eta=always				\
	--exitall_on_error=1			\
	--ioengine=libaio			\
	--iodepth=64				\
	--iodepth_batch=16			\
	--direct=1				\
	--numjobs=1				\
	--time_based				\
	--runtime=180				\
	--name=dst-pressure			\
	--rw=randwrite				\
	--fsync=1				\
	--bs=256k				\
	--filesize=512M			\
	--filename=/mnt/dst-pressure/hotfile	\
	>"$log" 2>&1 &
    echo $!
}

human_to_bytes()
{
    local value=$1

    awk -v value="$value" 'BEGIN {
	unit = substr(value, length(value), 1)
	num = value + 0

	if (unit == "K")
	    num *= 1000
	else if (unit == "M")
	    num *= 1000 * 1000
	else if (unit == "G")
	    num *= 1000 * 1000 * 1000
	else if (unit == "T")
	    num *= 1000 * 1000 * 1000 * 1000

	printf "%.0f\n", num
    }'
}

reconcile_bytes_moved()
{
    local moved

    moved=$(
	awk '
	    /^reconcile_/ { in_reconcile = 1; next }
	    /^[^[:space:]]/ { in_reconcile = 0 }
	    in_reconcile && $1 == "bytes" && $2 == "moved:" {
		print $3
		exit
	    }
	' /sys/fs/bcachefs/*/internal/moving_ctxts
    )

    if [[ -z $moved ]]; then
	echo 0
	return
    fi

    human_to_bytes "$moved"
}

move_write_window_violations()
{
    awk '
	$1 == "writes:" && $2 == "ios" && $4 == "sectors" {
	    split($3, ios, "/")
	    split($5, sectors, "/")
	    if (ios[1] + 0 > ios[2] + 0 ||
		sectors[1] + 0 > sectors[2] + 0)
		print
	}
    ' /sys/fs/bcachefs/*/internal/moving_ctxts
}

assert_move_write_windows()
{
    local violations

    violations=$(move_write_window_violations)
    if [[ -n $violations ]]; then
	echo "move writes exceeded effective in-flight window" >&2
	echo "$violations" >&2
	dump_evacuate_perf_debug >&2
	return 1
    fi
}

monitor_evacuate_progress()
{
    local pid=$1
    local min_bps=$2
    local interval=5
    local max_slow_windows=2
    local min_delta=$((min_bps * interval))
    local slow_windows=0
    local last current delta

    last=$(reconcile_bytes_moved)

    while kill -0 "$pid" 2>/dev/null; do
	sleep "$interval"

	current=$(reconcile_bytes_moved)
	delta=$((current - last))
	if (( delta < 0 )); then
	    delta=0
	fi

	printf 'evacuation progress window: %s bytes in %ss\n' \
	    "$delta" "$interval" >&2

	if ! assert_move_write_windows; then
	    return 1
	fi

	if (( delta < min_delta )); then
	    slow_windows=$((slow_windows + 1))
	else
	    slow_windows=0
	fi

	if (( slow_windows >= max_slow_windows )); then
	    echo "evacuation progress stalled below window floor" >&2
	    echo "minimum expected: $min_delta bytes per ${interval}s" >&2
	    dump_evacuate_perf_debug >&2
	    return 1
	fi

	last=$current
    done
}

evacuate_bytes_per_sec()
{
    local dev=$1
    local size=$2
    local min_progress_bps=${3:-0}
    local start end elapsed_ns
    local log=/tmp/evacuate_perf_device_evac.log
    local evacpid

    start=$(date +%s%N)
    bcachefs device evacuate "$dev" >"$log" 2>&1 &
    evacpid=$!

    if (( min_progress_bps )) &&
	! monitor_evacuate_progress "$evacpid" "$min_progress_bps"; then
	kill "$evacpid" 2>/dev/null || true
	wait "$evacpid" 2>/dev/null || true
	cat "$log"
	return 1
    fi

    if ! wait "$evacpid"; then
	cat "$log"
	return 1
    fi
    end=$(date +%s%N)

    elapsed_ns=$((end - start))
    (( elapsed_ns > 0 ))
    echo $((size * 1000000000 / elapsed_ns))
}

print_rate()
{
    local name=$1
    local bps=$2
    awk -v name="$name" -v bps="$bps" 'BEGIN {
	printf "%s: %.1f MiB/s\n", name, bps / 1048576
    }'
}

test_evacuate_not_much_slower_than_source_read()
{
    set_watchdog 600

    local data_size=$((512 * 1024 * 1024))
    local min_abs_bps=$((64 * 1024 * 1024))

    format_evacuate_perf_fs

    mount -t bcachefs "$(devs)" /mnt

    seed_source_data

    local read_bps
    read_bps=$(read_bytes_per_sec /mnt/src-only-data "$data_size")
    print_rate "source direct read" "$read_bps"

    local events
    events=$(trace_events | xargs)
    if [[ -n $events ]]; then
	setup_tracing "$events"
    fi

    local evac_bps
    evac_bps=$(evacuate_bytes_per_sec "${ktest_scratch_dev[0]}" "$data_size")
    print_rate "device evacuate" "$evac_bps"

    bcachefs fs usage -h --all /mnt
    cat /sys/fs/bcachefs/*/internal/moving_ctxts || true
    cat /sys/kernel/debug/bcachefs/*/write_points || true

    if (( evac_bps < min_abs_bps && evac_bps * 4 < read_bps )); then
	echo "evacuation is much slower than source direct read"
	dump_evacuate_perf_debug
	return 1
    fi

    umount /mnt
    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
}

test_evacuate_not_much_slower_with_busy_destination()
{
    set_watchdog 900

    local data_size=$((512 * 1024 * 1024))
    local min_abs_bps=$((64 * 1024 * 1024))
    local baseline_bps
    local contended_bps
    local fioout="$ktest_out/dst-pressure-fio-out"
    local fiopid

    format_evacuate_perf_fs
    mount -t bcachefs "$(devs)" /mnt
    seed_source_data

    baseline_bps=$(evacuate_bytes_per_sec "${ktest_scratch_dev[0]}" "$data_size")
    print_rate "baseline device evacuate" "$baseline_bps"

    umount /mnt
    bcachefs fsck -ny "${ktest_scratch_dev[@]}"

    format_evacuate_perf_fs
    mount -t bcachefs "$(devs)" /mnt
    seed_source_data

    local events
    events=$(trace_events | xargs)
    if [[ -n $events ]]; then
	setup_tracing "$events"
    fi

    fiopid=$(start_dst_pressure "$fioout")
    sleep 3

    if ! contended_bps=$(evacuate_bytes_per_sec \
	"${ktest_scratch_dev[0]}" "$data_size" "$((baseline_bps / 2))"); then
	cat "$fioout" || true
	kill "$fiopid" 2>/dev/null || true
	wait "$fiopid" 2>/dev/null || true
	dump_evacuate_perf_debug
	return 1
    fi
    print_rate "contended device evacuate" "$contended_bps"

    kill "$fiopid" 2>/dev/null || true
    wait "$fiopid" 2>/dev/null || true

    bcachefs fs usage -h --all /mnt
    cat /sys/fs/bcachefs/*/internal/moving_ctxts || true
    cat /sys/kernel/debug/bcachefs/*/write_points || true

    if (( contended_bps < min_abs_bps && contended_bps * 2 < baseline_bps )); then
	echo "evacuation is much slower when destination is busy"
	cat "$fioout" || true
	dump_evacuate_perf_debug
	return 1
    fi

    umount /mnt
    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
}

main "$@"
