#!/usr/bin/env bash

. $(dirname $(readlink -e ${BASH_SOURCE[0]}))/bcachefs-test-libs.sh

config-scratch-devs 1G
config-scratch-devs 1G
config-scratch-devs 16G
config-scratch-devs 16G

run_basic_tiering_test()
{
    run_basic_fio_test "$@"			\
	--block_size=4k				\
	--btree_node_size=32k			\
	--bucket_size=256k				\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}		\
	--label=ssd.ssd2 ${ktest_scratch_dev[1]}		\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}		\
	--label=hdd.hdd2 ${ktest_scratch_dev[3]}		\
	--foreground_target=ssd			\
	--promote_target=ssd			\
	--background_target=hdd
}

test_tiering_torture()
{
    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--bucket_size=2M				\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=ssd.ssd2 ${ktest_scratch_dev[1]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--label=hdd.hdd2 ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[1]}:${ktest_scratch_dev[2]}:${ktest_scratch_dev[3]} /mnt
    run_fio_randrw
    mv /mnt/fiotest /mnt/fiotest_old

    # Sustained rewrite pressure to drive promote/demote cycling. 10 loops
    # of the 3.5G job is ~20 minutes on the slow (lockdep) configs;
    # run_fio_randrw's own 1200s watchdog is sized for a single loop, so
    # set our own. (Was --loops=50, which could never fit any watchdog
    # we'd want to wait out.)
    set_watchdog 3600
    run_fio					\
	--name=randrw				\
	--rw=randrw				\
	--bsrange=4k-1M				\
	--loops=10

    mount -o remount,ro /mnt
    umount /mnt

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_tiering()
{
    run_basic_tiering_test
}

test_tiering_misaligned()
{
    run_basic_tiering_test
    run_basic_fio_test "$@"				\
	--block_size=4k					\
	--btree_node_size=32k				\
	--bucket_size=61952				\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=ssd.ssd2 ${ktest_scratch_dev[1]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--label=hdd.hdd2 ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd
}

test_tiering_drop_alloc()
{
    run_basic_tiering_test
    # mount dropping all alloc info

    echo "dropping alloc:"
    mount -t bcachefs -o dangerously_reconstruct_alloc,fsck,fix_errors "$(join_by : "${ktest_scratch_dev[@]}")" /mnt
    umount /mnt

    echo "final fsck:"

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_tiering_buffered()
{
    set_watchdog 6000

    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=ssd.ssd2 ${ktest_scratch_dev[1]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--label=hdd.hdd2 ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd

    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt

    local loops=$((($ktest_priority + 1) * 4))

    fio --eta=always				\
	--exitall_on_error=1			\
	--ioengine=sync				\
	--numjobs=1				\
	--verify=crc32c				\
	--verify_fatal=1			\
	--buffer_compress_percentage=30		\
	--filename=/mnt/fiotest		    	\
	--filesize=3500M			\
	--loops=$loops				\
	--name=randrw				\
	--rw=randrw				\
	--bsrange=512-16k
    umount /mnt

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_foreground_target_full_fallback()
{
    set_watchdog 180

    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--bucket_size=256k				\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    # The foreground target is only a preference.  This write is larger than
    # the SSD scratch device, so it must complete by falling back to HDD space
    # instead of waiting forever on SSD/copygc progress.
    dd if=/dev/zero of=/mnt/foreground-target-fallback bs=16M count=96	\
	oflag=direct status=progress
    sync
    bcachefs fs usage -h /mnt

    umount /mnt

    bcachefs fsck -ny ${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_writethrough()
{
    run_basic_fio_test "$@"								\
	--durability=0 --label=ssd ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}	\
	--durability=1 --label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd								\
	--promote_target=ssd								\
	--background_target=hdd
}

test_promote()
{
    run_basic_fio_test "$@"			\
	--durability=0 --label=ssd ${ktest_scratch_dev[0]}	\
	--durability=1 --label=hdd ${ktest_scratch_dev[2]}	\
	--foreground_target=hdd			\
	--promote_target=ssd			\
	--background_target=hdd
}

test_setattr()
{
    setup_tracing `bcachefs_slowpath_tracepoints`

    run_quiet "" bcachefs format -f				\
	--durability=0 --label=ssd ${ktest_scratch_dev[0]}	\
	--durability=1 --label=hdd ${ktest_scratch_dev[2]}	\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    touch /mnt/foo
    touch /mnt/bar

    bcachefs set-file-option --foreground_target $(basename ${ktest_scratch_dev[0]}) /mnt/
    bcachefs set-file-option --promote_target ssd /mnt/

    umount /mnt

    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_tiering_no_checksum()
{
    run_basic_tiering_test --data_checksum=none
}

test_tiering_compression()
{
    run_basic_tiering_test --compression=lz4
}

test_tiering_crypto()
{
    run_basic_tiering_test --encrypted --no_passphrase	
}

test_tiering_crypto_lz4()
{
    run_basic_tiering_test --encrypted --no_passphrase --compression=lz4
}

test_tiering_crypto_zstd()
{
    run_basic_tiering_test --encrypted --no_passphrase --compression=zstd
}

test_tiering_replication()
{
    run_basic_tiering_test --replicas=2
}

test_tiering_variable_buckets()
{
    run_basic_fio_test					\
	--label=ssd --bucket_size=32k	${ktest_scratch_dev[0]}	\
	--label=ssd --bucket_size=64k	${ktest_scratch_dev[1]}	\
	--label=hdd --bucket_size=128k	${ktest_scratch_dev[3]}	\
	--label=hdd --bucket_size=256k	${ktest_scratch_dev[2]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd
}

test_tiering_variable_buckets_replicas()
{
    setup_tracing 'bcachefs:data_update bcachefs:data_update_key_fail'

    run_basic_fio_test					\
	--replicas=2					\
	--label=ssd --bucket_size=32k	${ktest_scratch_dev[0]}	\
	--label=ssd --bucket_size=64k	${ktest_scratch_dev[1]}	\
	--label=hdd --bucket_size=128k	${ktest_scratch_dev[3]}	\
	--label=hdd --bucket_size=256k	${ktest_scratch_dev[2]}	\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd
}

test_device_add()
{
    set_watchdog 240
    run_quiet "" bcachefs format -f					\
	--label=ssd ${ktest_scratch_dev[0]}				\
	--label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]}:${ktest_scratch_dev[3]} /mnt

    run_fio_randrw|tail -n200 &

    bcachefs device add -f --label=hdd /mnt ${ktest_scratch_dev[1]}

    wait
    umount /mnt

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_device_remove()
{
    set_watchdog 240
    setup_tracing 'bcachefs:trans_restart_relock'

    run_quiet "" bcachefs format -f					\
	--replicas=2							\
	--label=ssd ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}	\
	--label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd						\
	--promote_target=ssd						\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt

    run_fio_randrw|tail -n200 &

    sleep 5
    bcachefs device remove -f ${ktest_scratch_dev[1]} /mnt

    wait
    umount /mnt

    bcachefs fsck -n "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_device_remove_background()
{
    set_watchdog 240
    setup_tracing 'bcachefs:trans_restart_relock'

    run_quiet "" bcachefs format -f					\
	--errors=ro					\
	--replicas=2							\
	--label=ssd ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}	\
	--label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd						\
	--promote_target=ssd						\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt

    bcachefs device resize-journal ${ktest_scratch_dev[0]} 512M
    bcachefs device resize-journal ${ktest_scratch_dev[1]} 512M
    bcachefs device resize-journal ${ktest_scratch_dev[2]} 512M
    bcachefs device resize-journal ${ktest_scratch_dev[3]} 512M

    run_fio_randrw|tail -n200 &

    sleep 5
    bcachefs device remove -f ${ktest_scratch_dev[2]} /mnt

    wait
    umount /mnt

    bcachefs fsck -n "${ktest_scratch_dev[@]}"
    bcachefs reset-counters --counters=data_update_fail ${ktest_scratch_dev[0]}
    bcachefs reset-counters --counters=bucket_alloc_fail ${ktest_scratch_dev[0]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_device_remove_rewrites_metadata()
{
    set_watchdog 240

    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--bucket_size=256k				\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--metadata_target=ssd				\
	--foreground_target=hdd				\
	--promote_target=ssd				\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    # Populate enough small-file metadata that the SSD metadata target owns
    # btree nodes.  Device removal has to rewrite those nodes elsewhere before
    # dropping the SSD member's metadata pointers.
    for i in $(seq 0 100000); do
	echo $i > /mnt/file-$i
    done
    sync
    bcachefs fs usage -h --all /mnt

    bcachefs device remove ${ktest_scratch_dev[0]} /mnt
    bcachefs fs usage -h /mnt

    umount /mnt

    bcachefs fsck -ny ${ktest_scratch_dev[2]}
    bcachefs_test_end_checks ${ktest_scratch_dev[2]}
}

test_mount_umount_torture()
{
    set_watchdog 60
    run_quiet "" bcachefs format -f					\
	--replicas=2							\
	--label=ssd ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}	\
	--label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd						\
	--promote_target=ssd						\
	--background_target=hdd

    for i in {0..10}; do
	mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt
	umount /mnt
    done

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_change_replicas()
{
    set_watchdog 180
    run_quiet "" bcachefs format -f					\
	--label=ssd ${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]}	\
	--label=hdd ${ktest_scratch_dev[2]} ${ktest_scratch_dev[3]}	\
	--foreground_target=ssd						\
	--promote_target=ssd						\
	--background_target=hdd

    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt

    (
	cd /sys/fs/bcachefs/*
	while true; do
	    echo 1 > options/data_replicas
	    sleep 0.1
	    echo 2 > options/data_replicas
	    sleep 0.1
	done
    ) &

    loops=$((($ktest_priority + 1) * 4))

    fio --eta=always				\
	--numjobs=1				\
	--buffer_compress_percentage=50		\
	--filename=/mnt/fiotest		    	\
	--filesize=1500M			\
	--loops=$loops				\
	--name=randrw				\
	--rw=randrw				\
	--bsrange=4k-1M	

#    while true; do
#	dd if=/dev/zero of=/mnt/foo bs=1M count=1024 oflag=direct
#	sync
#	#rm /mnt/foo
#    done

    kill %1
    umount /mnt

    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_concurrent_all_device_removal()
{
    set_watchdog 120

    run_quiet "" bcachefs format -f			\
	--label=ssd.ssd1 ${ktest_scratch_dev[0]}	\
	--label=ssd.ssd2 ${ktest_scratch_dev[1]}	\
	--label=hdd.hdd1 ${ktest_scratch_dev[2]}	\
	--label=hdd.hdd2 ${ktest_scratch_dev[3]}	\
	--replicas=2					\
	--foreground_target=ssd				\
	--promote_target=ssd				\
	--background_target=hdd

    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt

    dd if=/dev/zero of=/mnt/foo bs=128M count=40 oflag=direct

    # Fill cache
    for i in 1 2 3 4; do cat /mnt/foo > /dev/null; done

    bcachefs device remove ${ktest_scratch_dev[0]} &
    bcachefs device remove ${ktest_scratch_dev[1]} &
    bcachefs device remove ${ktest_scratch_dev[2]} &
    bcachefs device remove ${ktest_scratch_dev[3]} &
    wait

    umount /mnt
    bcachefs fsck -ny $(join_by " " "${ktest_scratch_dev[@]}")

    # Test that no incufficient devices issues appears
    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt
    umount /mnt

    check_bcachefs_leaks
    check_bcachefs_errors ${ktest_scratch_dev[0]}
}

test_read_corrupt()
{
    ktest_expect_device_errors=1
    [[ ! -f /sys/module/bcachefs/parameters/read_corrupt_ratio ]] && return 0

    set_watchdog 300
    setup_tracing

    echo 8 > /sys/module/bcachefs/parameters/read_corrupt_ratio

    run_quiet "" bcachefs format -f			\
       --label=ssd.ssd1 ${ktest_scratch_dev[0]}		\
       --label=ssd.ssd2 ${ktest_scratch_dev[1]}		\
       --label=hdd.hdd1 ${ktest_scratch_dev[2]}		\
       --label=hdd.hdd2 ${ktest_scratch_dev[3]}		\
       --replicas=2					\
       --foreground_target=ssd				\
       --promote_target=ssd				\
       --background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt

    run_fio					\
	--name=randwrite			\
	--rw=randwrite				\
	--bsrange=4k-1M
    run_fio					\
	--name=randrread			\
	--rw=randread				\
	--bsrange=4k-1M

    echo 0 > /sys/module/bcachefs/parameters/read_corrupt_ratio

    # Check the read retry path for indirect extents:
    #cp --reflink /mnt/fiotest /mnt/fiotest.reflinked
    #dd if=/mnt/fiotest of=/dev/null bs=4k iflag=direct

    umount /mnt

    bcachefs fsck -ny ${ktest_scratch_dev[0]}
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_btree_read_corrupt()
{
    ktest_expect_device_errors=1
    [[ ! -f /sys/module/bcachefs/parameters/btree_read_corrupt_ratio ]] && return 0

    setup_tracing
    set_watchdog 180

    run_quiet "" bcachefs format -f			\
       --label=ssd.ssd1 ${ktest_scratch_dev[0]}		\
       --label=ssd.ssd2 ${ktest_scratch_dev[1]}		\
       --label=hdd.hdd1 ${ktest_scratch_dev[2]}		\
       --label=hdd.hdd2 ${ktest_scratch_dev[3]}		\
       --replicas=2					\
       --foreground_target=ssd				\
       --promote_target=ssd				\
       --background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt
    run_fio_randrw
    umount /mnt

    echo 8 > /sys/module/bcachefs/parameters/btree_read_corrupt_ratio
    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt
    echo 0 > /sys/module/bcachefs/parameters/btree_read_corrupt_ratio

    dd if=/mnt/fiotest of=/dev/null bs=1M
    umount /mnt

    bcachefs fsck -ny ${ktest_scratch_dev[0]}
    check_bcachefs_leaks
    check_bcachefs_counters ${ktest_scratch_dev[0]}
}

## reproducer for https://github.com/koverstreet/bcachefs/issues/834
# v1: works as expected, background target=device 0
test_metadata_on_wrong_device_after_disk_add_v1()
{
    run_quiet "" bcachefs format -f \
        --background_target=hdd \
        --foreground_target=hdd \
        --promote_target=hdd \
        --metadata_target=ssd \
        --label=hdd \
        ${ktest_scratch_dev[2]} \
        --label=ssd \
        ${ktest_scratch_dev[0]}

    mount -t bcachefs ${ktest_scratch_dev[2]}:${ktest_scratch_dev[0]} /mnt

    for i in $(seq 0 100000); do
        echo $i > /mnt/$i
    done

    bcachefs fs usage -h /mnt

    run_quiet "" bcachefs device add -f --label=hdd /mnt ${ktest_scratch_dev[3]}

    for i in $(seq 0 100000); do
        echo $i > /mnt/a$i
    done

    btree_devs=$(bcachefs fs usage -h --all /mnt/ | grep -c ^btree:)

    test $btree_devs -eq 1 || return 1

    umount /mnt
}

# v2: metadata ends up on wrong device, foreground target=device 0
test_metadata_on_wrong_device_after_disk_add_v2()
{
    run_quiet "" bcachefs format -f \
        --background_target=hdd \
        --foreground_target=hdd \
        --promote_target=hdd \
        --metadata_target=ssd \
        --label=ssd \
        ${ktest_scratch_dev[0]} \
        --label=hdd \
        ${ktest_scratch_dev[2]}

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    for i in $(seq 0 100000); do
        echo $i > /mnt/$i
    done

    sync
    bcachefs fs usage -h /mnt

    run_quiet "" bcachefs device add -f --label=hdd /mnt ${ktest_scratch_dev[3]}

    for i in $(seq 0 100000); do
        echo $i > /mnt/a$i
    done

    sync
    bcachefs fs usage -h /mnt

    btree_devs=$(bcachefs fs usage -h --all /mnt/ | grep -c ^btree:)

    test $btree_devs -eq 1 || return 1

    umount /mnt
}

test_recover_super()
{
    set_watchdog 120
    run_quiet "" bcachefs format -f ${ktest_scratch_dev[@]}
    bcachefs show-super -l ${ktest_scratch_dev[0]}

    mount -t bcachefs ${ktest_scratch_dev[0]} /mnt
    cp -rx /usr /mnt/usr
    umount /mnt

    echo "Wiping super"
    dd if=/dev/zero of=${ktest_scratch_dev[0]} bs=1M count=1 oflag=direct

    echo "Attempting mount, should fail"
    ! mount -t bcachefs ${ktest_scratch_dev[0]} /mnt

    echo "Recovering superblock"
    bcachefs recover-super --src_device ${ktest_scratch_dev[1]} --dev_idx 0 -y ${ktest_scratch_dev[0]}

    echo "Attempting mount, should succeed"
    echo "Fixing errors because recovered device will no longer have a journal"
    mount -t bcachefs -o fsck,fix_errors ${ktest_scratch_dev[0]} /mnt
    umount /mnt

    check_bcachefs_counters ${ktest_scratch_dev[0]}
}

test_mv_cross_subvol_io_opts()
{
    set_watchdog 60

    run_quiet "" bcachefs format -f			\
	--label=ssd ${ktest_scratch_dev[0]}		\
	--label=hdd ${ktest_scratch_dev[2]}		\
	--foreground_target=ssd				\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    # Dest subvol: override targets so data should land on hdd
    bcachefs subvolume create /mnt/dst
    bcachefs set-file-option --foreground_target=hdd /mnt/dst
    bcachefs set-file-option --background_target=hdd /mnt/dst

    # Write test file in root subvol (data goes to ssd via foreground_target)
    dd if=/dev/urandom of=/mnt/testfile bs=1M count=10 oflag=direct

    # mv across subvolumes: rename returns EXDEV, coreutils falls back to
    # copy_file_range (reflink) + unlink
    mv /mnt/testfile /mnt/dst/testfile

    # Verify data is still intact
    md5sum /mnt/dst/testfile

    # The destination reflink_p must have REFLINK_P_MAY_UPDATE_OPTIONS set
    # so the reconciler can move data to match dst subvol's IO path options.
    # Bug: bch2_remap_file_range() passes may_change_src_io_path_opts=false,
    # so the flag never gets propagated to the destination.
    umount /mnt

    local devs=(${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]})
    local extents=$(bcachefs list -b extents "${devs[@]}")

    if echo "$extents" | grep -q "reflink_p.*may_update_opts"; then
	echo "PASS: reflink_p has may_update_opts"
    elif echo "$extents" | grep -q reflink_p; then
	echo "FAIL: reflink_p missing may_update_opts flag"
	echo "Reconciler won't update IO path options after cross-subvol mv"
	echo "$extents" | grep reflink_p
	return 1
    else
	echo "No reflink_p found — mv did not use copy_file_range"
    fi

    bcachefs fsck -ny "${devs[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

test_reflink_option_propagate()
{
    set_watchdog 60

    run_quiet "" bcachefs format -f			\
	--label=ssd ${ktest_scratch_dev[0]}		\
	--label=hdd ${ktest_scratch_dev[2]}		\
	--foreground_target=ssd				\
	--background_target=hdd

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[2]} /mnt

    # Dst subvol with hdd targets — data should eventually move there
    bcachefs subvolume create /mnt/dst
    bcachefs set-file-option --foreground_target=hdd /mnt/dst
    bcachefs set-file-option --background_target=hdd /mnt/dst

    # Write test file in root subvol (goes to ssd via foreground_target)
    dd if=/dev/urandom of=/mnt/testfile bs=1M count=10 oflag=direct

    # Cross-subvol mv: coreutils uses copy_file_range (reflink) + unlink
    # This creates reflink_p extents with REFLINK_P_MAY_UPDATE_OPTIONS set
    mv /mnt/testfile /mnt/dst/testfile

    # Propagate dst subvol's IO options to reflinked indirect extents
    bcachefs reflink-option-propagate /mnt/dst/testfile

    # --set-may-update should be harmless on already-flagged extents
    bcachefs reflink-option-propagate --set-may-update /mnt/dst/testfile

    # Verify data integrity
    md5sum /mnt/dst/testfile

    umount /mnt

    local devs=(${ktest_scratch_dev[0]} ${ktest_scratch_dev[2]})
    bcachefs fsck -ny "${devs[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

# When an extent is made indirect, bch2_make_extent_indirect() must snapshot
# the source inode's IO options onto the new reflink_v: a non-degraded data
# extent carries no bch_extent_reconcile entry (the reconciler re-derives the
# options from the inode each pass), but an indirect extent has no inode to
# derive from, so without the snapshot the reconciler reconciles it against
# the filesystem defaults instead - which can ENOSPC the fs trying to bring
# every reflinked extent to the default replica count.
test_reflink_inode_opts()
{
    set_watchdog 60

    run_quiet "" bcachefs format -f			\
	--data_replicas=1				\
	${ktest_scratch_dev[0]}				\
	${ktest_scratch_dev[1]}

    mount -t bcachefs ${ktest_scratch_dev[0]}:${ktest_scratch_dev[1]} /mnt

    # A directory with a non-default (per-inode) data_replicas option;
    # files created under it inherit it.
    mkdir /mnt/d
    bcachefs set-file-option --data_replicas=2 /mnt/d
    dd if=/dev/urandom of=/mnt/d/foo bs=1M count=8 oflag=direct

    # foo's extents match the inode option, so they carry no
    # bch_extent_reconcile entry - the bug precondition.
    cp --reflink /mnt/d/foo /mnt/d/bar
    cmp /mnt/d/foo /mnt/d/bar

    umount /mnt

    local devs=(${ktest_scratch_dev[0]} ${ktest_scratch_dev[1]})
    local reflink_keys=$(bcachefs list -b reflink "${devs[@]}")
    echo "$reflink_keys"

    if echo "$reflink_keys" | grep -q "reconcile.*replicas=2 (inode)"; then
	echo "PASS: reflink_v carries the inode's reconcile opts (data_replicas=2)"
    else
	echo "FAIL: reflink_v missing the inode's reconcile opts"
	echo "  expected a reconcile entry with 'replicas=2 (inode)' on the reflink_v keys"
	return 1
    fi

    bcachefs fsck -ny "${devs[@]}"
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

main $@
