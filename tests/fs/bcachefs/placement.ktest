#!/usr/bin/env bash
#
# Placement policy tests.
#
# 7 equal devices with 3x replication is the XOR design's perfect case -
# PG(2, 2), the Fano plane: the triples {a, b, a ^ b} on 1-indexed
# device numbers cover every pair in exactly 7 combinations, vs
# C(7, 3) = 35 unconstrained. On a fresh filesystem with balanced
# devices the designed tier should win every pick - the balance veto
# never fires when the devices fill evenly - so the invariant asserted
# is exact, with no slack: every 3-device user-data replicas entry in
# the accounting is a Fano line.
#
# In its own file because the device count is the test: replication.ktest
# carries 5 scratch devices and several of its tests span all of them.

. $(dirname $(readlink -e "${BASH_SOURCE[0]}"))/bcachefs-test-libs.sh

config-scratch-devs 4G
config-scratch-devs 4G
config-scratch-devs 4G
config-scratch-devs 4G
config-scratch-devs 4G
config-scratch-devs 4G
config-scratch-devs 4G

test_placement_fano()
{
    set_watchdog 120

    run_quiet "" bcachefs format -f --replicas=3 "${ktest_scratch_dev[@]}"

    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt

    local i
    for i in $(seq 0 49); do
	dd if=/dev/urandom of=/mnt/f$i bs=1M count=4 oflag=direct status=none
    done

    # Clean shutdown flushes the accounting mem table to the btree;
    # remount so the debugfs keys reflect everything written:
    umount /mnt
    mount -t bcachefs "$(join_by : "${ktest_scratch_dev[@]}")" /mnt

    # The 7 Fano lines in 0-indexed sorted dev_idx form (1-indexed
    # members of each line xor to zero); replicas entries render sorted,
    # so plain string matching suffices:
    cat /sys/kernel/debug/bcachefs/*/btrees/accounting/keys |
    awk '
	BEGIN {
	    ok["0 1 2"] = ok["0 3 4"] = ok["0 5 6"] = ok["1 3 5"] = 1
	    ok["1 4 6"] = ok["2 3 6"] = ok["2 4 5"] = 1
	}
	/user: [0-9]+\/3 \[/ {
	    match($0, /\[[^]]*\]/)
	    t = substr($0, RSTART + 1, RLENGTH - 2)
	    total++
	    if (!(t in ok)) {
		bad++
		print "off-design user triple: [" t "]"
	    }
	}
	/btree: [0-9]+\/3 \[/ { nr_btree++ }
	END {
	    print total, "user data triples,", bad + 0, "off-design;", \
		  nr_btree + 0, "btree triples (unasserted)"
	    exit (bad || !total) ? 1 : 0
	}
    '

    umount /mnt
    bcachefs_test_end_checks ${ktest_scratch_dev[0]}
}

main "$@"
