#!/usr/bin/env bash

. $(dirname $(readlink -e "${BASH_SOURCE[0]}"))/bcachefs-test-libs.sh

require-kernel-config BCACHEFS_FS=y

config-mem 4G
config-scratch-devs 1G
config-scratch-devs 1G
config-scratch-devs 1G

devs()
{
    join_by : "${ktest_scratch_dev[@]}"
}

dump_move_flush_debug()
{
    bcachefs fs usage -h --all /mnt || true
    cat /sys/fs/bcachefs/*/internal/copy_gc_wait || true
    cat /sys/fs/bcachefs/*/reconcile_status || true
    cat /sys/fs/bcachefs/*/internal/moving_ctxts || true
    tail -n 800 /sys/kernel/tracing/trace || true
}

check_move_uses_journal_flush()
{
    for _ in $(seq 1 100); do
	if grep -q 'flags:.*flush,move' /sys/kernel/tracing/trace ||
	   grep -q 'flags:.*move,flush' /sys/kernel/tracing/trace; then
	    return 0
	fi
	sleep .1
    done

    echo "did not observe move write op marked for journal flush"
    dump_move_flush_debug
    return 1
}

check_move_writes_are_not_fua()
{
    if ! grep -Eq 'block_bio_queue: [0-9]+,[0-9]+ W[^ ]*SM [0-9]+ \+ 512' \
	/sys/kernel/tracing/trace; then
	echo "did not observe large moved-data writes in block trace"
	dump_move_flush_debug
	return 1
    fi

    if grep -Eq 'block_bio_queue: [0-9]+,[0-9]+ [A-Z]*F[A-Z]*SM [0-9]+ \+ 512' \
	/sys/kernel/tracing/trace; then
	echo "observed per-bio FUA on large moved-data write"
	dump_move_flush_debug
	return 1
    fi
}

wait_for_src_user_data_evacuated()
{
    local has_data

    for _ in $(seq 1 1200); do
	has_data=$(cat /sys/fs/bcachefs/*/dev-0/has_data)
	if ! grep -qw user <<< "$has_data"; then
	    return 0
	fi
	sleep .1
    done

    echo "source device still has user data after evacuation wait"
    dump_move_flush_debug
    return 1
}

test_move_writes_flush_journal_instead_of_fua()
{
    set_watchdog 240

    run_quiet "" bcachefs format -f			\
	--block_size=4k					\
	--bucket_size=256k				\
	--replicas=1					\
	--foreground_target=src			\
	--background_target=dst			\
	--rotational=1 --label=src ${ktest_scratch_dev[0]} \
	--rotational=1 --label=dst ${ktest_scratch_dev[1]} \
	--rotational=1 --label=dst ${ktest_scratch_dev[2]}

    mount -t bcachefs "$(devs)" /mnt

    dd if=/dev/zero of=/mnt/src-only-data bs=4M count=64 oflag=direct status=none
    sync

    setup_tracing 'bcachefs:data_update bcachefs:data_update_no_io bcachefs:data_update_read bcachefs:data_update_write block:block_bio_queue block:block_bio_complete'

    echo evacuating > /sys/fs/bcachefs/*/dev-0/state
    wait_for_src_user_data_evacuated
    check_move_uses_journal_flush
    check_move_writes_are_not_fua

    umount /mnt
    bcachefs fsck -ny "${ktest_scratch_dev[@]}"
    bcachefs_test_end_checks "${ktest_scratch_dev[0]}"
}

main "$@"
